{
  "name": "mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "dependencies": {
    "@expo/ui": "~57.0.3",
    "@expo/vector-icons": "^15.1.1",
    "@tamagui/babel-plugin": "^2.4.1",
    "@tamagui/config": "^2.4.1",
    "@tamagui/metro-plugin": "^2.4.1",
    "expo": "~57.0.2",
    "expo-constants": "~57.0.3",
    "expo-device": "~57.0.0",
    "expo-font": "~57.0.0",
    "expo-glass-effect": "~57.0.0",
    "expo-image": "~57.0.0",
    "expo-linking": "~57.0.1",
    "expo-localization": "~57.0.0",
    "expo-router": "~57.0.3",
    "expo-splash-screen": "~57.0.2",
    "expo-status-bar": "~57.0.0",
    "expo-symbols": "~57.0.0",
    "expo-system-ui": "~57.0.0",
    "expo-web-browser": "~57.0.0",
    "i18next": "^26.3.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-i18next": "^17.0.8",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.10.0",
    "tamagui": "^2.4.1"
  },
  "devDependencies": {
    "@testing-library/react-native": "^14.0.1",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.2.2",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~57.0.0",
    "jest": "^29.7.0",
    "jest-expo": "^57.0.1",
    "react-test-renderer": "^19.2.7",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "private": true,
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!.*(?:(jest-)?react-native|@react-native[^/]*|expo[^/]*|@expo[^/]*|react-navigation|@react-navigation[^/]*|tamagui|@tamagui[^/]*)/)"
    ],
    "moduleNameMapper": {
      "^@/assets/(.*)$": "<rootDir>/assets/$1",
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "setupFiles": [
      "<rootDir>/jest.setup.ts"
    ],
    "collectCoverageFrom": [
      "src/components/**/*.{ts,tsx}",
      "!src/components/**/style.ts",
      "!src/components/**/index.ts",
      "!src/components/**/*.test.{ts,tsx}",
      "!src/components/*.{ts,tsx}",
      "!src/components/*.web.{ts,tsx}",
      "!src/components/ui/**",
      "src/views/**/*.{ts,tsx}",
      "!src/views/**/style.ts",
      "!src/views/**/index.ts",
      "!src/views/**/*.test.{ts,tsx}",
      "src/utils/**/*.{ts,tsx}",
      "!src/utils/**/*.test.{ts,tsx}",
      "src/mocks/**/*.{ts,tsx}",
      "!src/mocks/**/*.test.{ts,tsx}"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 95,
        "functions": 95,
        "lines": 95,
        "statements": 95
      }
    }
  }
}
